# Database
DATABASE_URL=postgresql+psycopg://novelos:novelos@localhost:5432/novelos

# Auth
API_TOKEN=change-me-to-a-long-random-string

# v0.8 T-1 (§5.T): Key Encryption Key for ProviderKey api_key Fernet encryption.
# Required at startup — the process exits if missing or malformed. Generate one
# with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Treat it as you would any other secret: 600 perms, never commit, store in HZ
# secret manager / .env (not in the repo).
KEK_SECRET=replace-with-fernet-key-44-chars-base64-url=

# Grok
GROK_API_KEY=xai-...
GROK_BASE_URL=https://api.x.ai/v1
MODEL_NAME=grok-4
MODEL_NAME_FAST=grok-4-mini

# Misc
LOG_LEVEL=INFO
CORS_ORIGINS=*
