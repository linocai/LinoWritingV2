# Database
DATABASE_URL=postgresql+psycopg://novelos:novelos@localhost:5432/novelos

# Auth: v1.0.1 — a single fixed shared secret. Every request must present
# `Authorization: Bearer <API_TOKEN>`; the backend compares it against this one
# value (constant-time). Required at startup (min 16 chars) — the process exits
# if missing. The v0.9 multi-device pairing subsystem (QR / 6-digit codes) is
# gone; each client (macOS / iPhone / iPad) carries this same token in Keychain,
# entered once in Settings → 连接. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Treat it as a secret: 600 perms, never commit, store in HZ secret manager.
API_TOKEN=replace-with-a-long-random-shared-secret

# v0.8 T-1 (§5.T): Key Encryption Key for ProviderKey api_key Fernet encryption.
# Required at startup — the process exits if missing or malformed. Generate one
# with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Treat it as you would any other secret: 600 perms, never commit, store in HZ
# secret manager / .env (not in the repo).
KEK_SECRET=replace-with-fernet-key-44-chars-base64-url=

# Grok
GROK_API_KEY=xai-...
GROK_BASE_URL=https://api.x.ai/v1
MODEL_NAME=grok-4
MODEL_NAME_FAST=grok-4-mini

# Misc
LOG_LEVEL=INFO
CORS_ORIGINS=*
